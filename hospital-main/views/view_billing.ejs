<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Payment Status</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="page-shell">
    <div class="header-card">
        <h2>Payment Status</h2>
    </div>
    <div class="table-card">
        <table>
            <tr>
                <th>Patient</th>
                <th>Amount</th>
                <th>Source</th>
                <th>Status</th>
            </tr>
            <% bills.forEach(bill => { %>
                <tr>
                    <td><%= bill.patient ? bill.patient.name : 'Unknown' %></td>
                    <td>₹<%= bill.amount %></td>
                    <td><%= bill.source %></td>
                    <td class="<%= bill.status.toLowerCase() %>"><%= bill.status %></td>
                </tr>
            <% }) %>
        </table>
        <a class="back-link" href="/admin">⬅ Back</a>
    </div>
</div>
</body>
</html>
